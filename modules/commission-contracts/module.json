      "method": "GET"
    },
    {
      "path": "sozlesme-imza/{token}",
      "handler": "frontend_sign_submit",
      "type": "frontend",
      "method": "POST"
    },
    {
      "path": "sozlesme-imza/{token}/pdf",
      "handler": "frontend_sign_pdf",
      "type": "frontend",
      "method": "GET"
    }
  ],
  "permissions": [
    "commission-contracts.view",
    "commission-contracts.create",
    "commission-contracts.edit",
    "commission-contracts.delete"
  ],
  "settings": false,
  "hooks": {
    "actions": [],
    "filters": []
  }
